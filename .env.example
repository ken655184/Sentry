# ===== 應用基本 =====
APP_NAME=MonitorSystem
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ===== 認證 =====
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# 預設 admin (首次啟動建立,之後強制改)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin1234
DEFAULT_ADMIN_EMAIL=admin@example.com

# ===== 認證 DB (SQLite) =====
AUTH_DB_URL=sqlite+aiosqlite:///./data/auth.db

# ===== 外部 Python DB 模組設定 (留空給你填) =====
# EXTERNAL_DB_MODULE=your_module.db_client
# EXTERNAL_DB_ENDPOINT=http://internal-db-service/api

# ===== Server 檔案資源路徑 (留空給你填) =====
FS_LOG_PATH=/var/log/monitor
FS_CONFIG_PATH=/etc/monitor
FS_ARTIFACT_PATH=/data/artifacts

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
